{
	"name": "horserace",
	"version": "1.0.0",
	"description": "",
	"main": "app.ts",
	"scripts": {
		"test": "NODE_ENV=test jest",
		"dev": "nodemon --exec tsx app.ts",
		"build": "rimraf ./dist && tsc -p tsconfig.json",
		"start": "node dist/app.js",
		"initTestData": "npm run recreateDb && sequelize db:migrate && sequelize db:seed:all",
		"recreateDb": "npx ts-node database/SetupDatabase.ts",
		"tests": "clear && npm test"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"jest": {
		"preset": "ts-jest",
		"testMatch": [
			"<rootDir>/**/*.test.ts"
		],
		"moduleFileExtensions": [
			"ts",
			"js",
			"json",
			"node"
		],
		"testTimeout": 5000,
		"globalSetup": "./tests/jest/globalSetup.js",
		"globalTeardown": "./tests/jest/globalTeardown.ts",
		"setupFiles": [
			"./tests/jest/setupFile.js"
		],
		"testEnvironment": "node"
	},
	"dependencies": {
		"@fastify/cookie": "^9.1.0",
		"@fastify/cors": "^10.0.1",
		"@fastify/formbody": "^8.0.1",
		"@fastify/jwt": "^9.0.1",
		"@fastify/swagger": "^9.2.0",
		"@fastify/swagger-ui": "^5.1.0",
		"axios": "^1.7.7",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"mysql2": "^3.10.3",
		"sequelize": "^6.37.3",
		"uecs": "^0.4.2",
		"ws": "^8.16.0"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"fastify": "^5.1.0",
		"jest": "^29.7.0",
		"nodemon": "^3.1.4",
		"rimraf": "^6.0.1",
		"sequelize-cli": "^6.6.2",
		"sqlite3": "^5.1.7",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-node": "^10.9.2",
		"tsx": "^3.12.10",
		"typescript": "^5.5.4"
	}
}
